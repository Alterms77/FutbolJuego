*.mdb.meta

# Crashlytics
crashlytics-build.properties
fabric.properties

# OS junk
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# Node / Firebase Functions
Backend/functions/node_modules/
Backend/functions/.runtimeconfig.json
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# Secrets
*.keystore
*.p12
*.mobileprovision
google-services.json
GoogleService-Info.plist

# Build artifacts
*.apk
*.aab
*.ipa
